<!DOCTYPE html>
<html>
<head>
    <title>Survey Form</title>
</head>
<body>

<h1>Feedback Survey</h1>

<form>
    Name:
    <input type="text"><br><br>

    Age:
    <input type="number"><br><br>

    Favorite Language:
    <select>
        <option>Python</option>
        <option>C++</option>
        <option>Java</option>
    </select>

    <br><br>

    Comments:
    <br>
    <textarea rows="4" cols="30"></textarea>

    <br><br>

    <input type="submit">
</form>

</body>
</html>
