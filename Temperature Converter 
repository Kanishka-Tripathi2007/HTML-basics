<!DOCTYPE html>
<html>
<head>
    <title>Temperature Converter</title>
</head>
<body>

<input type="number" id="celsius">

<button onclick="convert()">Convert to Fahrenheit</button>

<p id="result"></p>

<script>
function convert() {
    let c = document.getElementById("celsius").value;
    let f = (c * 9/5) + 32;

    document.getElementById("result").innerHTML =
        f + " °F";
}
</script>

</body>
</html>