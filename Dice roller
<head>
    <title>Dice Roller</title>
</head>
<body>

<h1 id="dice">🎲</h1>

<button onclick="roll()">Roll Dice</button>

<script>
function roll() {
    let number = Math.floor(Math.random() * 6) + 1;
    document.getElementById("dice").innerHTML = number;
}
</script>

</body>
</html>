<!DOCTYPE html>
<html>
<head>
    <title>Dice Roller</title>
</head>
<body>

<h1 id="dice">🎲</h1>

<button onclick="roll()">Roll Dice</button>

<script>
function roll() {
    let number = Math.floor(Math.random() * 6) + 1;
    document.getElementById("dice").innerHTML = number;
}
</script>

</body>
</html>