<!DOCTYPE html>
<html>
<head>
    <title>Character Counter</title>
</head>
<body>

<textarea id="text" onkeyup="count()"></textarea>

<p id="result">Characters: 0</p>

<script>
function count() {
    let text =
        document.getElementById("text").value.length;

    document.getElementById("result").innerHTML =
        "Characters: " + text;
}
</script>

</body>
</html>